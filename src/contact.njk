<h6 class="title">Contact</h6>
<ul id="contact_data">
  <li>
    <img src="/assets/images/icons/mail.png" alt="Email" />
    <p>{{ site.email | replace("@", "[at]") }}</p>
  </li>
  <li>
    <img src="/assets/images/icons/mail.png" alt="Academic Email" />
    <a href="mailto:farnaz.faraji@newcastle.ac.uk">farnaz.faraji[at]newcastle.ac.uk</a>
  </li>
  {%- for link in site.social %}
  <li>
    <img src="{{ link.icon }}" alt="{{ link.name }}" />
    <a href="{{ link.url }}" target="_blank">{{ link.name }}</a>
  </li>
  {%- endfor %}
  <li>
    <img src="/assets/images/icons/goodreads.png" alt="Goodreads" />
    <a href="https://www.goodreads.com/user/show/196708221-naz-faraji" target="_blank">Goodreads</a>
  </li>
</ul>
